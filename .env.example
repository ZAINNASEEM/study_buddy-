# Enable local Firebase emulators
REACT_APP_USE_FIREBASE_EMULATORS=true

# Firestore emulator host and port
REACT_APP_FIRESTORE_EMULATOR_HOST=localhost
REACT_APP_FIRESTORE_EMULATOR_PORT=8080

# Auth emulator URL (includes protocol)
REACT_APP_AUTH_EMULATOR_URL=http://localhost:9099

# Storage emulator host and port
REACT_APP_STORAGE_EMULATOR_HOST=localhost
REACT_APP_STORAGE_EMULATOR_PORT=9199

# Optional: you can also set your Firebase project id for dev convenience
REACT_APP_FIREBASE_PROJECT_ID=studybuddy-a1da4
